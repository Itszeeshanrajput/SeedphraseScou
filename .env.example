# ═══════════════════════════════════════════════════════════════
# ETH BRUTE FORCE 2026 - PROFESSIONAL EDITION
# Configuration Template
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# ⚡ PERFORMANCE SETTINGS
# ───────────────────────────────────────────────────────────────

# Number of addresses to check per batch
# Recommended: 100-1000 (higher = faster but more RPC load)
BATCH_SIZE=500

# Number of worker threads for wallet generation
# Auto-optimal if not set (uses CPU cores - 1)
# Range: 2-8
WORKER_THREADS=6

# Maximum addresses to cache (LRU eviction)
# Recommended: 1000000-5000000
CACHE_SIZE=2000000

# Minimum ETH balance to report (in ETH)
MIN_BALANCE=0.001


# ───────────────────────────────────────────────────────────────
# 🌐 RPC API KEYS (Optional - Higher Rate Limits)
# ───────────────────────────────────────────────────────────────
# Leave as-is for free tier, or add your keys for higher limits

# Alchemy (Free: 300M Compute Units/month)
# Get key: https://www.alchemy.com/
ALCHEMY_API_KEY=demo

# Infura (Free: 100K requests/day)
# Get key: https://www.infura.io/
INFURA_API_KEY=demo

# Ankr (Free: 200M Compute Units/month)
# Get key: https://www.ankr.com/
ANKR_API_KEY=


# ───────────────────────────────────────────────────────────────
# 🔌 WEBSOCKET RPC (Optional)
# ───────────────────────────────────────────────────────────────

# WebSocket endpoint for real-time data
# Default: ethereum.publicnode.com (free, unlimited)
WS_RPC=wss://ethereum.publicnode.com


# ───────────────────────────────────────────────────────────────
# 💾 REDIS CACHE (Optional - Persistent Across Restarts)
# ───────────────────────────────────────────────────────────────

# Enable Redis caching (false = use memory cache)
USE_REDIS=false

# Redis connection URL
REDIS_URL=redis://localhost:6379


# ───────────────────────────────────────────────────────────────
# 📊 EXAMPLE CONFIGURATIONS
# ───────────────────────────────────────────────────────────────

# For Maximum Speed (if RPC allows):
# BATCH_SIZE=1000
# WORKER_THREADS=8

# For Low-End Systems:
# BATCH_SIZE=100
# WORKER_THREADS=2
# CACHE_SIZE=500000

# For Production (with API keys):
# ALCHEMY_API_KEY=your_actual_key_here
# BATCH_SIZE=1000
# WORKER_THREADS=8

# ═══════════════════════════════════════════════════════════════
# Save this file as .env to use your custom configuration
# ═══════════════════════════════════════════════════════════════
